{
  "name": "@gutshot/api",
  "version": "1.0.0",
  "private": true,
  "description": "GUTSHOT Poker Club — Backend API (NestJS)",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
