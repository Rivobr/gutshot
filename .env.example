# ---------------------------------
# GUTSHOT Poker Club — Environment Variables Example
# ---------------------------------

# App
NODE_ENV=development
API_PORT=3000
API_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://gutshot:gutshot@localhost:5432/gutshot?schema=public
POSTGRES_USER=gutshot
POSTGRES_PASSWORD=gutshot
POSTGRES_DB=gutshot
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d
JWT_ADMIN_SECRET=change_me_admin
JWT_ADMIN_EXPIRES_IN=1d

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Mini App
VITE_API_URL=http://localhost:3000/api/v1

# Admin Panel
VITE_ADMIN_API_URL=http://localhost:3000/api/v1
